# ─── Environment ──────────────────────────────────────────────────────────────
PIPELINE_ENV=local
CORS_ORIGINS=http://100.64.5.96:3001,http://100.64.5.96:3000

# ─── LLM Routing (9router-first) ─────────────────────────────────────────────
# Use the OpenAI-compatible base URL from your 9router server.
# Examples:
#   NINE_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
#   NINE_ROUTER_BASE_URL=https://your-9router-domain.example/v1
LLM_PROVIDER=nine_router
FORCE_V2_PIPELINE=true
ALLOW_DIRECT_PROVIDER_FALLBACKS=false
TRANSCRIPTION_PROVIDER=local
NINE_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
NINE_ROUTER_API_KEY=
NINE_ROUTER_MODEL=CliperHub
NINE_ROUTER_PASS1_MODEL=CliperHub
NINE_ROUTER_PASS2_MODEL=CliperHub
NINE_ROUTER_AI_LAYER_MODEL=CliperHub
NINE_ROUTER_TIMEOUT=120
NINE_ROUTER_MAX_RETRIES=3
NINE_ROUTER_WHISPER_ENABLED=true
NINE_ROUTER_WHISPER_MODEL=groq/whisper-large-v3-turbo
NINE_ROUTER_WHISPER_TIMEOUT=120
NINE_ROUTER_WHISPER_MAX_RETRIES=1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/autoclip.db

# ─── Direct provider keys (disabled by default) ──────────────────────────────
# Keep these empty when ALLOW_DIRECT_PROVIDER_FALLBACKS=false.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-64-char-random-hex-string
JWT_REFRESH_SECRET_KEY=generate-another-64-char-random-hex-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Superadmin Seed ──────────────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@autocliper.com
SUPERADMIN_PASSWORD=YourSecurePassword123!

# ─── Whisper ──────────────────────────────────────────────────────────────────
WHISPER_MODEL_PATH=/path/to/ggml-medium.bin
WHISPER_BINARY_PATH=/path/to/whisper-cli
WHISPER_THREADS=4

# ─── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=tmp/output
DOWNLOAD_DIR=tmp/downloads
WAV_DIR=/tmp/pipeline/wav

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_VIDEO_DURATION=3600
MAX_CONCURRENT_JOBS=1
MAX_WHISPER_PARALLEL=1
MAX_RENDER_WORKERS=2
MIN_RAM_GB=1
MIN_DISK_GB=2

# ─── Asset Fetcher API Keys ───────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=
GIPHY_API_KEY=

# ─── Dev/Testing ──────────────────────────────────────────────────────────────
# 0 = process all clips, N = limit to N clips (faster dev iteration)
VIDEO_FINAL_RESULT=0

# ─── Groq API (optional direct fallback only) ────────────────────────────────
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_LLM_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_MAX_RETRIES=3
GROQ_TIMEOUT=60

# ─── V2 Pipeline Tuning ──────────────────────────────────────────────────────
V2_PIPELINE_ENABLED=true
V2_CHUNK_MAX_SECONDS=600
V2_CHUNK_MAX_CHARS=4000
V2_AUDIO_PADDING_SECONDS=3.0
V2_VAD_SEARCH_RADIUS=2.0
V2_VAD_MIN_SILENCE_MS=300
V2_MAX_AUDIO_CHUNK_MB=25

# ─── Speaker Diarization (PyAnnote) ──────────────────────────────────────────
# Requires HuggingFace token with access to pyannote/speaker-diarization-3.1
# Get token: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=
DIARIZATION_ENABLED=true
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_TIMEOUT_SEC=60
DIARIZATION_MIN_SPEAKERS=2
DIARIZATION_MAX_SPEAKERS=4
DIARIZATION_MAPPING_CONFIDENCE_THRESHOLD=0.5

# ─── Ollama (Local LLM for V2 Analysis) ──────────────────────────────────────
OLLAMA_BASE_URL=http://100.64.5.96:11434
OLLAMA_MODEL=mistral-nemo:12b

# ─── Remotion Render Engine ───────────────────────────────────────────────────
USE_REMOTION=true
REMOTION_PROJECT_PATH=../remotion-renderer
REMOTION_SERVER_URL=http://localhost:3002
REMOTION_SERVER_PORT=3002
REMOTION_CONCURRENCY=2
REMOTION_QUALITY=medium
REMOTION_ENABLE_THREEJS=false
REMOTION_ENABLE_AI_LAYER=true

# Subtitle timing offset (seconds). Negative = earlier subtitle.
# Adjust if subtitle appears late (-0.5) or early (+0.5) relative to audio.
REMOTION_SUBTITLE_OFFSET=-0.5

# Optional AI cinematic text / YOLO11 person segmentation
YOLO_SEG_MODEL=models/yolo11n-seg.pt
TEXT_EMPHASIS_MAX_EVENTS=2
TEXT_EMPHASIS_SEG_CONFIDENCE=0.35
TEXT_EMPHASIS_MASK_FEATHER=9

# ─── Person-First Reframe ────────────────────────────────────────────────────
# person_first = production path; legacy/shadow for rollback/A-B only
REFRAME_PIPELINE_MODE=person_first
PERSON_DETECTOR=rfdetr-large
# Lower (0.25–0.30) if 2nd person is small/side-on and missed; raise if ghosts appear
PERSON_CONF_THRESHOLD=0.35
PERSON_TRACKER=botsort
TRACKER_MAX_LOST_FRAMES=8
FACE_DETECTOR=retinaface
FACE_CONFIDENCE=0.55


# ─── ClipScout API ────────────────────────────────────────────────────────────
CLIPSCOUT_API_URL=https://www.clipscout.app/api/search
CLIPSCOUT_TIMEOUT=15
CLIPSCOUT_MAX_RETRIES=2
CLIPSCOUT_ENABLED_SOURCES=pexels,pixabay,youtube_cc,youtube_protected

# ─── B-Roll Splice ───────────────────────────────────────────────────────────
BROLL_SPLICE_ENABLED=true
BROLL_SPLICE_MAX_PER_CLIP=3
BROLL_SPLICE_CROSSFADE_SEC=0.15
BROLL_MAX_FOOTAGE_SIZE_MB=50
