# ─── Environment ──────────────────────────────────────────────────────────────
PIPELINE_ENV=local

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/autoclip_v1

# ─── Gemini (supports multiple keys: key1,key2,key3) ─────────────────────────
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-64-char-random-hex-string
JWT_REFRESH_SECRET_KEY=generate-another-64-char-random-hex-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Superadmin Seed ──────────────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@autocliper.com
SUPERADMIN_PASSWORD=YourSecurePassword123!

# ─── Whisper ──────────────────────────────────────────────────────────────────
WHISPER_MODEL_PATH=/path/to/ggml-medium.bin
WHISPER_BINARY_PATH=/path/to/whisper-cli
WHISPER_THREADS=4

# ─── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=tmp/output
DOWNLOAD_DIR=tmp/downloads
WAV_DIR=/tmp/pipeline/wav

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_VIDEO_DURATION=3600
MAX_CONCURRENT_JOBS=1
MAX_WHISPER_PARALLEL=1
MAX_RENDER_WORKERS=2
MIN_RAM_GB=1
MIN_DISK_GB=2

# ─── Asset Fetcher API Keys ───────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=
GIPHY_API_KEY=

# ─── Dev/Testing ──────────────────────────────────────────────────────────────
# 0 = process all clips, N = limit to N clips (faster dev iteration)
VIDEO_FINAL_RESULT=0

# ─── Groq API (V2 Pipeline — Non-Premium) ────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_LLM_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_MAX_RETRIES=3
GROQ_TIMEOUT=60

# ─── V2 Pipeline Tuning ──────────────────────────────────────────────────────
V2_PIPELINE_ENABLED=true
V2_CHUNK_MAX_SECONDS=600
V2_CHUNK_MAX_CHARS=4000
V2_AUDIO_PADDING_SECONDS=3.0
V2_VAD_SEARCH_RADIUS=2.0
V2_VAD_MIN_SILENCE_MS=300
V2_MAX_AUDIO_CHUNK_MB=25

# ─── Ollama (Local LLM for V2 Analysis) ──────────────────────────────────────
OLLAMA_BASE_URL=http://100.64.5.96:11434
OLLAMA_MODEL=mistral-nemo:12b
