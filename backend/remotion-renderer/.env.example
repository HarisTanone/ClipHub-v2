# Remotion Render Server Configuration

# Server
PORT=3001
NODE_ENV=development

# Render Settings
RENDERER_CONCURRENCY=2
RENDERER_QUALITY=medium
RENDERER_OUTPUT_DIR=../tmp/output
ASSETS_DIR=../assets

# Feature Flags
ENABLE_THREEJS=true
ENABLE_AI_LAYER=false

# Remotion
REMOTION_CODEC=h264
REMOTION_OUTPUT_FORMAT=mp4
REMOTION_FRAMERATE=30
REMOTION_DEFAULT_WIDTH=1080
REMOTION_DEFAULT_HEIGHT=1920

# Logging
LOG_LEVEL=info
