# ═══════════════════════════════════════════════════════════════════════════════
# ClipHub-v2 — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local
*.key
*.pem
*.cert

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.whl

# ─── Virtual Environment ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
.npm/
.yarn/

# ─── Data & Output (runtime generated) ───────────────────────────────────────
backend/tmp/
backend/data/
*.mp4
*.mp3
*.wav
*.webm
*.sqlite
*.db

# ─── Frontend Build Artifacts ─────────────────────────────────────────────────
frontend/dist/
frontend/test-results/
frontend/tsconfig.tsbuildinfo

# ─── Remotion ─────────────────────────────────────────────────────────────────
remotion-renderer/node_modules/
remotion-renderer/dist/
remotion-renderer/output/
.remotion/
.cache/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── PID files (deploy) ──────────────────────────────────────────────────────
.pids/

# ─── Kiro ─────────────────────────────────────────────────────────────────────
.kiro/

# ─── ML Models (too large for git) ───────────────────────────────────────────
*.pt
*.bin
*.onnx
*.pb
*.task
*.tflite
models/
backend/models/

# ─── Data Archives / Backups ──────────────────────────────────────────────────
9router-data-*.tar.gz
*.tar.gz

# ─── Root-level runtime files ─────────────────────────────────────────────────
data/

# ─── Coverage / Testing ──────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ─── Agent skills (local reference only) ─────────────────────────────────────
.agents/
skills-lock.json
